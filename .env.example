# Strava OAuth2 app credentials — https://www.strava.com/settings/api
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:3000/api/strava/callback

# Postgres connection string for persisting daily step counts (Neon, or any
# Postgres works). On Vercel this is injected automatically once a Postgres
# database is linked to the project.
DATABASE_URL=

# Shared secret the Health Auto Export iOS app must send (as the
# x-webhook-secret header, or a ?secret= query param) when POSTing to
# /api/webhooks/apple-health. Generate any random string.
HEALTH_WEBHOOK_SECRET=
